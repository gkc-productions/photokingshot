generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BookingInquiry {
  id            String   @id @default(cuid())
  fullName      String
  email         String
  phone         String
  shootType     String
  preferredDate DateTime?
  location      String
  message       String
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlogPost {
  id                String     @id @default(cuid())
  title             String
  slug              String     @unique
  excerpt           String
  content           String
  category          String
  status            BlogStatus @default(DRAFT)
  hasAffiliateLinks Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([status, category])
}

model AffiliateProduct {
  id           String   @id @default(cuid())
  title        String
  category     String
  bestFor      String
  description  String
  affiliateUrl String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, category])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  category    String
  imageUrl    String
  description String
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isFeatured, category])
}

model ClientGallery {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  clientName     String
  clientEmail    String?
  sessionDate    DateTime?
  description    String?
  accessCode     String         @unique
  passwordHash   String
  isPublished    Boolean        @default(false)
  allowDownloads Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  images         GalleryImage[]

  @@index([isPublished, slug])
  @@index([accessCode])
}

model GalleryImage {
  id             String        @id @default(cuid())
  galleryId      String
  imageUrl       String
  title          String?
  caption        String?
  sortOrder      Int           @default(0)
  isDownloadable Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  gallery        ClientGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId, sortOrder])
}
